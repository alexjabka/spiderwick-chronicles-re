[ENABLE]
// TEST: NOP all 3 calls to sub_51ABE0 (portal traversal via kallis VM)
// Purpose: determine if portal system is ADDITIVE (adds visible rooms)
//          or SUBTRACTIVE (hides rooms from full set)
//
// If rooms DISAPPEAR after enabling → portal is additive → need different approach
// If ALL rooms APPEAR → portal is subtractive → just NOP it
// If rooms FREEZE → portal updates visibility each frame
//
// Call sites:
//   0x4889CC  in SectorVisibilityUpdate2 (sub_488970) — main render path
//   0x48CC2D  in sub_48CBE0 — secondary render path
//   0x4905DB  in sub_490580 — third render path (coop?)

// Path 1: SectorVisibilityUpdate2
Spiderwick.exe+889CC:
db 90 90 90 90 90

// Path 2: sub_48CBE0
Spiderwick.exe+8CC2D:
db 90 90 90 90 90

// Path 3: sub_490580
Spiderwick.exe+905DB:
db 90 90 90 90 90

[DISABLE]
// Restore original: call sub_51ABE0

// Path 1: e8 0f 22 09 00
Spiderwick.exe+889CC:
db E8 0F 22 09 00

// Path 2: e8 ae df 08 00
Spiderwick.exe+8CC2D:
db E8 AE DF 08 00

// Path 3: e8 00 a6 08 00
Spiderwick.exe+905DB:
db E8 00 A6 08 00
